// Place your key bindings in this file to overwrite the defaults
[
  {
    "key": "ctrl+shift+cmd+q",
    "command": "workbench.action.quit"
  },
  {
    "key": "cmd+q",
    "command": "-workbench.action.quit"
  },
  {
    "key": "cmd+up",
    "command": "-cursorTop",
    "when": "textInputFocus"
  },
  {
    "key": "cmd+down",
    "command": "-cursorBottom",
    "when": "textInputFocus"
  },
  {
    "key": "shift+cmd+up",
    "command": "-cursorTopSelect",
    "when": "textInputFocus"
  },
  {
    "key": "shift+cmd+down",
    "command": "-cursorBottomSelect",
    "when": "textInputFocus"
  },
  {
    "key": "cmd+r",
    "command": "workbench.action.reloadWindow",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+t",
    "command": "workbench.action.gotoMethod",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+shift+t",
    "command": "workbench.action.showAllSymbols",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+c",
    "command": "class-helper.addConstructor"
  },
  {
    "key": "ctrl+alt+c",
    "command": "class-helper.addPrivateProperties"
  },
  {
    "key": "alt+m",
    "command": "class-helper.addMehtod"
  },
  {
    "key": "ctrl+alt+m",
    "command": "class-helper.addPrivateMehtod"
  },
  {
    "key": "cmd+i",
    "command": "composerMode.agent"
  },
  {
    "key": "alt+cmd+s",
    "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
    "when": "!isAuxiliaryWindowFocusedContext"
  }
]
