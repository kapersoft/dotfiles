{
  "[blade.php]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter",
    "editor.formatOnSave": true,
  },
  "[git-commit]": {
    "editor.rulers": [72],
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[php]": {
    "editor.defaultFormatter": "open-southeners.laravel-pint",
    "editor.formatOnSave": true,
  },
  "[tsx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
  },
  "breadcrumbs.enabled": true,
  "breadcrumbs.symbolSortOrder": "type",
  "class-helper.php.property.visibility": "protected",
  "cursor.cmdk.useThemedDiffBackground": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.diffs.useCharacterLevelDiffs": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.sortJSON": "never",
  },
  "editor.codeLens": false,
  "editor.detectIndentation": true,
  "editor.emptySelectionClipboard": false,
  "editor.foldingImportsByDefault": false,
  "editor.foldingStrategy": "auto",
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.guides.bracketPairs": "active",
  "editor.lineHeight": 20,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.quickSuggestions": {
    "comments": true,
    "other": true,
    "strings": true,
  },
  "editor.quickSuggestionsDelay": 0,
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "selection",
  "editor.rulers": [80, 120],
  "editor.snippetSuggestions": "top",
  "editor.stickyScroll.enabled": true,
  "editor.suggest.showSnippets": false,
  "editor.suggestFontSize": 12,
  "editor.suggestLineHeight": 16,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 4,
  "editor.wordSeparators": "`~!@#%^&*()=+-[{]}\\|;:'\",.<>/?",
  "eslint.debug": false,
  "eslint.enable": true,
  "eslint.packageManager": "yarn",
  "eslint.run": "onType",
  "eslint.trace.server": "off",
  "eslint.validate": ["javascript", "vue"],
  "explorer.openEditors.visible": 0,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.php": "php",
    ".php_cs": "php",
    ".php_cs.dist": "php",
  },
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.idea": true,
    // "**/node_modules": true,
    "**/vendor": false,
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/vendor": true,
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openDiffOnClick": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "githubPullRequests.pullBranch": "never",
  "gitlens.advanced.messages": {
    "suppressCommitNotFoundWarning": true,
  },
  "gitlens.codeLens.scopes": ["document"],
  "gitlens.keymap": "chorded",
  "inline-parameters.enabled": false,
  "inline-parameters.hideRedundantAnnotations": false,
  "inline-parameters.showPhpDollar": true,
  "intelephense.files.exclude": [
    "**/.git/**",
    "**/.svn/**",
    "**/.hg/**",
    "**/CVS/**",
    "**/.DS_Store/**",
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**/{Test,test,Tests,tests}/**",
    "dev/**",
  ],
  "intelephense.trace.server": "verbose",
  "javascript.format.enable": true,
  "javascript.format.insertSpaceBeforeFunctionParenthesis": true,
  "javascript.referencesCodeLens.enabled": true,
  "javascript.updateImportsOnFileMove.enabled": "never",
  "javascript.validate.enable": false,
  "laravel-pint.enable": true,
  "namespaceResolver.autoSort": true,
  "namespaceResolver.showMessageOnStatusBar": true,
  "namespaceResolver.sortAlphabetically": true,
  "namespaceResolver.sortNatural": false,
  "namespaceResolver.sortOnSave": true,
  "php-cs-fixer.autoFixBySemicolon": true,
  "php-cs-fixer.executablePath": "${extensionPath}/php-cs-fixer.phar",
  "php-cs-fixer.lastDownload": 0,
  "php.suggest.basic": false,
  "php.validate.enable": true,
  "php.validate.executablePath": "/Users/jwkaper/Library/Application Support/Herd/bin/php",
  "php.validate.run": "onSave",
  "phpclassgen.vendor": "",
  "phpmd.enabled": false,
  "phpmd.rules": "phpmd-ruleset.xml",
  "phpstan.binCommand": [
    "/Users/jwkaper/Library/Application Support/Herd/bin//herd",
    "php",
    "vendor/bin/phpstan",
  ],
  "phpstan.singleFileMode": true,
  "prettier.resolveGlobalModules": true,
  "search.exclude": {
    "**/node_modules": true,
  },
  "search.showLineNumbers": true,
  "security.promptForLocalFileProtocolHandling": false,
  "sortJSON.excludedFiles": ["package.json", "composer.json"],
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.shellIntegration.enabled": false,
  "todohighlight.include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.html",
    "**/*.php",
    "**/*.css",
    "**/*.scss",
    "**/*.vue",
    "**/*.styl",
  ],
  "todohighlight.isEnable": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vscode_custom_css.imports": [
    "file:///Users/jwkaper/.vscode/hide-title-bar.css",
  ],
  "vue.server.hybridMode": "typeScriptPluginOnly",
  "window.title": "${activeEditorMedium}${separator}${rootName} ${dirty}",
  "workbench.colorCustomizations": {
    "editor.findMatchBackground": "#be1c1e",
    "editorIndentGuide.activeBackground": "#546e7a",
  },
  "workbench.colorTheme": "GitHub Light Default",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.labelFormat": "medium",
  "workbench.editor.showTabs": "single",
  "workbench.editorAssociations": {
    "*.mdc": "default",
  },
  "workbench.fontAliasing": "auto",
  "workbench.iconTheme": "Monokai Pro Icons",
  "workbench.panel.defaultLocation": "right",
  "workbench.settings.editor": "json",
  "workbench.settings.useSplitJSON": true,
  "workbench.sideBar.location": "right",
  "workbench.tree.renderIndentGuides": "always",
  "zenMode.fullScreen": false,
  "update.mode": "silentlyApplyOnQuit",
}
